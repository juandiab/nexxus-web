# ─── Email (Contact Form) ──────────────────────────────────────────────────────
# Google Workspace (Gmail SMTP). Use an App Password — not your normal login password.
# Create one: https://myaccount.google.com/apppasswords
#
# SMTP_USER = the Google account you sign in with (must match the App Password account).
# CONTACT_TO / CONTACT_FROM = the public contact alias on the site.
# For CONTACT_FROM to work, add contact@nexxus-tech.com under Gmail → Settings →
# "Send mail as" for juan.otalvaro@nexxus-tech.com (alias must be verified).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=juan.otalvaro@nexxus-tech.com
SMTP_PASS=your-16-char-app-password-here

CONTACT_TO=contact@nexxus-tech.com
CONTACT_FROM=contact@nexxus-tech.com

# ─── AI Chat (configure when ready) ───────────────────────────────────────────
AI_PROVIDER=anthropic          # anthropic | openai | custom
AI_API_KEY=your-api-key-here
AI_MODEL=claude-3-5-haiku-20241022

# ─── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
CORS_ORIGINS=https://nexxus-tech.com,https://www.nexxus-tech.com
